# ============================================
#  crypto-intel  .env.example  (v0.5 完整清单)
#  复制成 .env 并按需填入;留空则相关功能跳过
# ============================================

# --- LLM / AI 简报 (v0.4+) -------------------------------------------------
# 方式 A: 直连 Anthropic API (需付费 key)
ANTHROPIC_API_KEY=
# 方式 B: 本地 claude CLI (免 key, 需 Mac 已装 Claude Code)
#   代码自动探测: 没有 ANTHROPIC_API_KEY 时回落到 llm_brief_local.py

# --- 通知: Feishu 群机器人 (v0.4+) -----------------------------------------
FEISHU_WEBHOOK_URL=
# 可选: 签名密钥 (飞书开启"签名校验"时必填)
FEISHU_SECRET=
# 可选: 群名 (用于日志/多群分发标识)
FEISHU_GROUP_NAME=

# --- 通知: Telegram Bot (备选推送) -----------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 数据源: CryptoPanic 新闻 API (可选) -----------------------------------
CRYPTOPANIC_TOKEN=
