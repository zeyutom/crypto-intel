# 复制为 secrets.toml 后填入真实值。secrets.toml 不要 commit 到 git。
# 部署到 Streamlit Cloud 时, 在 App settings → Secrets 粘贴本文件内容即可。

# 仪表盘访问密码 (改成你自己的, 越复杂越好)
dashboard_password = "change-me-please"

# 可选: 如果想让 Streamlit Cloud 直接拉数据 (而不是只读 GitHub 上的 SQLite)
# 这些 API 都是免费的, 没有 key 也能用, 留空即可
[api_keys]
cryptopanic = ""
